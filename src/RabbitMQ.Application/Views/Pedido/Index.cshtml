@{
    ViewData["Title"] = "Monitor de Pedidos";
    Layout = "_Layout";
}

<!-- Stats cards -->
<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="fw-bold mb-0">
                        <i class="bi bi-activity text-primary me-2"></i>
                        Monitor de Pedidos
                    </h2>
                    <p class="text-muted mb-0">Atualizações em tempo real via SignalR</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span id="connection-badge" class="badge bg-secondary px-3 py-2">
                        <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>
                        Conectando...
                    </span>
                    <button class="btn btn-outline-danger btn-sm" onclick="limparTabela()">
                        <i class="bi bi-trash me-1"></i>Limpar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Métricas -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi bi-box-seam text-primary fs-4"></i>
                        </div>
                        <div>
                            <p class="text-muted mb-0 small">Total Recebidos</p>
                            <h3 class="fw-bold mb-0" id="total-count">0</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-success bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi bi-check-circle text-success fs-4"></i>
                        </div>
                        <div>
                            <p class="text-muted mb-0 small">Processados</p>
                            <h3 class="fw-bold mb-0 text-success" id="success-count">0</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-danger bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi bi-x-circle text-danger fs-4"></i>
                        </div>
                        <div>
                            <p class="text-muted mb-0 small">Falhos (DLQ)</p>
                            <h3 class="fw-bold mb-0 text-danger" id="error-count">0</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi bi-currency-dollar text-warning fs-4"></i>
                        </div>
                        <div>
                            <p class="text-muted mb-0 small">Volume Total</p>
                            <h3 class="fw-bold mb-0 text-warning" id="total-value">R$ 0,00</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-0">
            <div class="d-flex align-items-center justify-content-between">
                <h5 class="fw-semibold mb-0">Pedidos em tempo real</h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary active"
                            onclick="filtrar('todos', this)">
                        Todos
                    </button>
                    <button class="btn btn-sm btn-outline-success"
                            onclick="filtrar('Processado', this)">
                        Processados
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            onclick="filtrar('Falhou', this)">
                        Falhos
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="pedidos-table">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-semibold small text-uppercase">
                                Pedido ID
                            </th>
                            <th class="py-3 text-muted fw-semibold small text-uppercase">
                                Cliente
                            </th>
                            <th class="py-3 text-muted fw-semibold small text-uppercase">
                                Valor
                            </th>
                            <th class="py-3 text-muted fw-semibold small text-uppercase">
                                Status
                            </th>
                            <th class="py-3 text-muted fw-semibold small text-uppercase">
                                Motivo
                            </th>
                            <th class="py-3 text-muted fw-semibold small text-uppercase">
                                Processado em
                            </th>
                        </tr>
                    </thead>
                    <tbody id="pedidos-tbody">
                        <tr id="empty-row">
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                Aguardando pedidos...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script>
        let todos = [];
        let filtroAtual = 'todos';
        let totalValue = 0;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/pedidoHub")
            .withAutomaticReconnect()
            .build();

        // Recebe novo pedido do servidor
        connection.on("NovoPedido", function (pedido) {
            todos.unshift(pedido); // mais novo no topo
            atualizarMetricas(pedido);
            if (filtroAtual === 'todos' || filtroAtual === pedido.status) {
                adicionarLinha(pedido, true);
            }
        });

        connection.onreconnecting(() => {
            document.getElementById('connection-badge').className = 'badge bg-warning px-3 py-2';
            document.getElementById('connection-badge').innerHTML =
                '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Reconectando...';
        });

        connection.onreconnected(() => {
            document.getElementById('connection-badge').className = 'badge bg-success px-3 py-2';
            document.getElementById('connection-badge').innerHTML =
                '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Conectado';
        });

        connection.start().then(() => {
            document.getElementById('connection-badge').className = 'badge bg-success px-3 py-2';
            document.getElementById('connection-badge').innerHTML =
                '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Conectado';
        }).catch(err => {
            document.getElementById('connection-badge').className = 'badge bg-danger px-3 py-2';
            document.getElementById('connection-badge').innerHTML =
                '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Desconectado';
            console.error(err);
        });

        function adicionarLinha(pedido, animado) {
            const tbody = document.getElementById('pedidos-tbody');
            const emptyRow = document.getElementById('empty-row');
            if (emptyRow) emptyRow.remove();

            const isSuccess = pedido.status === 'Processado';
            const tr = document.createElement('tr');
            if (animado) tr.classList.add('table-row-new');

            tr.setAttribute('data-status', pedido.status);
            tr.innerHTML = `
                <td class="ps-4">
                    <span class="font-monospace small text-muted">
                        ${pedido.pedidoId.substring(0, 8)}...
                    </span>
                </td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar-circle bg-primary bg-opacity-10 text-primary">
                            ${pedido.clienteEmail.charAt(0).toUpperCase()}
                        </div>
                        <span class="small">${pedido.clienteEmail}</span>
                    </div>
                </td>
                <td>
                    <span class="fw-semibold">
                        ${pedido.valorTotal.toLocaleString('pt-BR', {
                            style: 'currency', currency: 'BRL'
                        })}
                    </span>
                </td>
                <td>
                    <span class="badge rounded-pill ${isSuccess
                        ? 'bg-success bg-opacity-10 text-success'
                        : 'bg-danger bg-opacity-10 text-danger'} px-3 py-2">
                        <i class="bi ${isSuccess
                            ? 'bi-check-circle-fill'
                            : 'bi-x-circle-fill'} me-1"></i>
                        ${pedido.status}
                    </span>
                </td>
                <td class="text-muted small">
                    ${pedido.motivo ?? '<span class="text-muted">—</span>'}
                </td>
                <td class="text-muted small">
                    ${new Date(pedido.processadoEm).toLocaleString('pt-BR')}
                </td>
            `;

            tbody.insertBefore(tr, tbody.firstChild);

            // Remove animação após terminar
            setTimeout(() => tr.classList.remove('table-row-new'), 1000);
        }

        function atualizarMetricas(pedido) {
            const total = parseInt(document.getElementById('total-count').textContent) + 1;
            document.getElementById('total-count').textContent = total;

            if (pedido.status === 'Processado') {
                const success = parseInt(document.getElementById('success-count').textContent) + 1;
                document.getElementById('success-count').textContent = success;
                totalValue += pedido.valorTotal;
                document.getElementById('total-value').textContent =
                    totalValue.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            } else {
                const errors = parseInt(document.getElementById('error-count').textContent) + 1;
                document.getElementById('error-count').textContent = errors;
            }
        }

        function filtrar(status, btn) {
            filtroAtual = status;
            document.querySelectorAll('.btn-outline-secondary, .btn-outline-success, .btn-outline-danger')
                .forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const tbody = document.getElementById('pedidos-tbody');
            tbody.innerHTML = '';

            const filtrados = status === 'todos'
                ? todos
                : todos.filter(p => p.status === status);

            if (filtrados.length === 0) {
                tbody.innerHTML = `
                    <tr id="empty-row">
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                            Nenhum pedido encontrado
                        </td>
                    </tr>`;
                return;
            }

            filtrados.forEach(p => adicionarLinha(p, false));
        }

        function limparTabela() {
            todos = [];
            totalValue = 0;
            document.getElementById('total-count').textContent = '0';
            document.getElementById('success-count').textContent = '0';
            document.getElementById('error-count').textContent = '0';
            document.getElementById('total-value').textContent = 'R$ 0,00';
            document.getElementById('pedidos-tbody').innerHTML = `
                <tr id="empty-row">
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                        Aguardando pedidos...
                    </td>
                </tr>`;
        }
    </script>
}